# PostgreSQL
# POSTGRES_PASSWORD must match the password in DATABASE_URL below.
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=changeme

# 'postgres' is the service name in docker-compose — do not use localhost.
DATABASE_URL=postgres://emailtelegram:changeme@postgres:5432/emailtelegram

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Email receiving domain — aliases will be name@MAIL_DOMAIN.
# Use the zone root that Cloudflare Email Routing handles, e.g. example.com.
MAIL_DOMAIN=example.com

# Public HTTPS base URL of this server (used to build attachment download links)
PUBLIC_BASE_URL=https://mail.example.com

# HTTP server listen port
HTTP_PORT=3000

# HMAC secret for signing attachment download tokens
# Generate with: openssl rand -hex 32
HMAC_SECRET=changeme

# Shared secret between Cloudflare Worker and VPS (cloudflare mode)
# Generate with: openssl rand -hex 32
WORKER_SECRET=changeme

# Storage directories
ATTACHMENT_DIR=/data/attachments
RAW_EMAIL_DIR=/data/rawemails

# Retention in hours (default 336 = 14 days)
ATTACHMENT_TTL_HOURS=336
RAW_EMAIL_TTL_HOURS=336
# Delivery log / attempt row retention in days (default 30)
DELIVERY_LOG_RETENTION_DAYS=30

# Optional attachment/raw storage encryption at rest.
# "none" keeps current plaintext-on-disk behavior.
# "local-v1" enables envelope encryption using MASTER_ENCRYPTION_KEY.
STORAGE_ENCRYPTION_MODE=none
# Generate with: openssl rand -base64 32
# MASTER_ENCRYPTION_KEY=
# Optional label stored with wrapped keys to help rotation bookkeeping.
# MASTER_ENCRYPTION_KEY_ID=local-env-v1
# Optional read-only older keys for staged rotation, formatted as:
# key-id-1=base64_or_hex_key;key-id-2=base64_or_hex_key
# MASTER_ENCRYPTION_KEYRING=
# Warning: do not switch back to STORAGE_ENCRYPTION_MODE=none or change the key id
# while encrypted files still exist unless the old key remains in MASTER_ENCRYPTION_KEYRING.

# Maximum accepted message size in bytes (default 10 MiB)
MAX_SIZE_BYTES=10485760

# Comma-separated Telegram user IDs to allow on first run.
# Set at least one operator here for the initial deployment, otherwise the bot
# will start but nobody will be authorized to manage aliases.
# INITIAL_ALLOWED_USERS=123456789

# Nightly DB backup directory (optional — omit to disable)
# BACKUP_DIR=/data/backups
# Optional: encrypt the nightly dump archive itself.
# Valid values: off, storage-key
# "storage-key" reuses MASTER_ENCRYPTION_KEY / MASTER_ENCRYPTION_KEYRING.
# Requires STORAGE_ENCRYPTION_MODE=local-v1.
# Recommended setting when storage encryption is enabled:
# BACKUP_ARCHIVE_ENCRYPTION=storage-key
# Database backups do not include attachment/raw mail files.
# If STORAGE_ENCRYPTION_MODE=local-v1, keep the matching MASTER_ENCRYPTION_KEY and
# reuse the same ATTACHMENT_DIR / RAW_EMAIL_DIR paths for restores. Encrypted
# backup archives can be restored with:
# MASTER_ENCRYPTION_KEY=... node dist/backupArchiveCli.js decrypt \
#   backup-YYYY-MM-DD.sql.gz.etg \
#   restored.sql.gz \
#   backup-YYYY-MM-DD.meta
# If the backup used an older key id, also set MASTER_ENCRYPTION_KEYRING with the
# matching read-only legacy key.

# Uptime monitoring (optional)
# Ping URL on each healthy cycle — e.g. https://hc-ping.com/<uuid> (healthchecks.io)
# HEALTHCHECKS_URL=https://hc-ping.com/your-uuid-here
# Telegram chat ID to receive critical alerts (e.g. your own DM chat ID)
# ALERT_CHAT_ID=123456789

# Prometheus metrics endpoint (optional)
# Generate with: openssl rand -hex 32
# METRICS_ENABLED=false
# METRICS_TOKEN=

# Hosted SaaS / billing mode (optional; self-hosted deployments can ignore)
# Valid values: self-hosted, hosted
# APP_MODE=self-hosted
# Hosted shared mail domain used when APP_MODE=hosted, e.g. inbox.example.com.
# HOSTED_MAIL_DOMAIN=inbox.example.com
# Valid values: none, stripe
# BILLING_PROVIDER=none
# Required only when BILLING_PROVIDER=stripe.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PERSONAL_MONTHLY=price_...
# STRIPE_PRICE_PERSONAL_YEARLY=price_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_YEARLY=price_...
# STRIPE_PRICE_TEAM_MONTHLY=price_...
# STRIPE_PRICE_TEAM_YEARLY=price_...
# BILLING_SUCCESS_URL=https://mail.example.com/billing/success
# BILLING_CANCEL_URL=https://mail.example.com/billing/cancel

# Internal operator admin UI (optional; hosted deployments only)
# Generate secrets with: openssl rand -hex 32
# ADMIN_ENABLED=false
# ADMIN_SECRET=
# Optional separate cookie/session signing secret. Defaults to ADMIN_SECRET.
# ADMIN_SESSION_SECRET=
# ADMIN_SESSION_TTL_MINUTES=60

# Logging
LOG_LEVEL=info
NODE_ENV=production
