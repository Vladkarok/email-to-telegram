{
  "uid": "e2t-app",
  "title": "Email to Telegram \u2013 Application",
  "tags": ["email-to-telegram", "application"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "query",
        "label": "Env",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(up, env)",
          "refId": "Prometheus-env-Variable-Query"
        },
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "staging",
          "value": "staging",
          "selected": true
        }
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Organizations",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(email_to_telegram_organizations_total{env=~\"$env\"})",
          "legendFormat": "orgs"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Users (total)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(email_to_telegram_users{state=\"total\",env=~\"$env\"})",
          "legendFormat": "users"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Chats (active)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(email_to_telegram_chats{state=\"active\",env=~\"$env\"})",
          "legendFormat": "active chats"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Aliases (active)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(email_to_telegram_aliases{status=\"active\",env=~\"$env\"})",
          "legendFormat": "aliases"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP requests rate by status_class",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status_class) (rate(email_to_telegram_http_requests_total{env=~\"$env\"}[5m]))",
          "legendFormat": "{{status_class}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP p95 latency",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(email_to_telegram_http_request_duration_seconds_bucket{env=~\"$env\"}[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Delivery success rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(email_to_telegram_delivery_attempts_total{result=\"succeeded\",env=~\"$env\"}[5m])) / clamp_min(sum(rate(email_to_telegram_delivery_attempts_total{env=~\"$env\"}[5m])), 1e-9)",
          "legendFormat": "success rate"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Telegram send failures by error_class",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (error_class) (rate(email_to_telegram_telegram_send_failures_total{env=~\"$env\"}[5m]))",
          "legendFormat": "{{error_class}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Attachments storage (GB)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "email_to_telegram_attachments_stored_bytes{env=~\"$env\"} / 1024 / 1024 / 1024",
          "legendFormat": "GB"
        }
      ]
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "Active organizations by plan",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 16,
        "x": 8,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (plan) (email_to_telegram_active_organizations{env=~\"$env\"})",
          "legendFormat": "{{plan}}"
        }
      ]
    }
  ]
}
