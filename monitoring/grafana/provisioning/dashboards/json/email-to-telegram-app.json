{
  "uid": "e2t-app",
  "title": "Email to Telegram – Application",
  "tags": ["email-to-telegram", "application"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "query",
        "label": "Env",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(up, env)",
          "refId": "Prometheus-env-Variable-Query"
        },
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "prod",
          "value": "prod",
          "selected": true
        }
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Scrape up",
      "description": "Prometheus target health for the app. DOWN means the app process or its /metrics endpoint is unreachable.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "min(up{job=~\"email_to_telegram_(staging|prod)\",env=~\"$env\"})",
          "legendFormat": "up"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "App restarts (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(changes(process_start_time_seconds{job=~\"email_to_telegram_(staging|prod)\",env=~\"$env\"}[24h]))",
          "legendFormat": "restarts"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Inbound accepted (24h)",
      "description": "Emails accepted by /inbound/raw in the last 24h. 0 for a whole day usually means the Worker → app contract is broken (see the 2026-06 incident) or genuinely no mail.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(email_to_telegram_raw_inbound_total{result=\"accepted\",env=~\"$env\"}[24h]))",
          "legendFormat": "accepted"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Permanently failed retries (7d)",
      "description": "Deliveries the retry worker gave up on — user-visible mail loss. Anything above 0 deserves a look.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(email_to_telegram_retry_attempts_total{result=\"permanently_failed\",env=~\"$env\"}[7d]))",
          "legendFormat": "permanently failed"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Deferred deliveries (24h)",
      "description": "Deliveries pushed to the retry worker because the in-flight cap was reached — backpressure signal.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(email_to_telegram_deliveries_deferred_total{env=~\"$env\"}[24h]))",
          "legendFormat": "deferred"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Quota rejections (7d)",
      "description": "Emails rejected because a user hit plan limits — early signal a free user is outgrowing their plan.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(email_to_telegram_quota_rejections_total{env=~\"$env\"}[7d]))",
          "legendFormat": "quota rejections"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Inbound emails per hour (accepted vs rejected)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (increase(email_to_telegram_raw_inbound_total{env=~\"$env\"}[1h]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Inbound rejections by reason (per hour)",
      "description": "raw = /inbound/raw contract failures (signature, replay, schema); preflight = pre-acceptance rejections. A sustained raw-rejection plateau with zero accepted = broken Worker contract.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (increase(email_to_telegram_raw_inbound_total{result=\"rejected\",env=~\"$env\"}[1h]))",
          "legendFormat": "raw: {{reason}}"
        },
        {
          "refId": "B",
          "expr": "sum by (reason) (increase(email_to_telegram_inbound_preflight_total{result=\"rejected\",env=~\"$env\"}[1h]))",
          "legendFormat": "preflight: {{reason}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Deliveries per hour by result",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (increase(email_to_telegram_delivery_attempts_total{env=~\"$env\"}[1h]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Delivery success rate (1h window)",
      "description": "Gaps mean no delivery attempts in the window — that is idle, not failure. (The old panel clamped the denominator and drew a misleading 0% while idle.)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "spanNulls": false }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(email_to_telegram_delivery_attempts_total{result=\"succeeded\",env=~\"$env\"}[1h])) / sum(rate(email_to_telegram_delivery_attempts_total{env=~\"$env\"}[1h]))",
          "legendFormat": "success rate"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Retry attempts per hour by result",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (increase(email_to_telegram_retry_attempts_total{env=~\"$env\"}[1h]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Telegram send failures per hour by error_class",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (error_class) (increase(email_to_telegram_telegram_send_failures_total{env=~\"$env\"}[1h]))",
          "legendFormat": "{{error_class}}"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Quota rejections per hour by reason",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (increase(email_to_telegram_quota_rejections_total{env=~\"$env\"}[1h]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "HTTP requests rate by status_class",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status_class) (rate(email_to_telegram_http_requests_total{env=~\"$env\"}[$__rate_interval]))",
          "legendFormat": "{{status_class}}"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "HTTP p95 latency by route (probe routes excluded)",
      "description": "Excludes /healthz and /metrics so scrape/probe traffic does not mask real endpoint latency.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(email_to_telegram_http_request_duration_seconds_bucket{env=~\"$env\",route!~\"/healthz|/metrics\"}[$__rate_interval])))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Users (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 36 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(email_to_telegram_users{state=\"total\",env=~\"$env\"})",
          "legendFormat": "users"
        }
      ]
    },
    {
      "id": 17,
      "type": "stat",
      "title": "Users (allowed)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 36 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(email_to_telegram_users{state=\"allowed\",env=~\"$env\"})",
          "legendFormat": "allowed"
        }
      ]
    },
    {
      "id": 18,
      "type": "bargauge",
      "title": "Activation funnel",
      "description": "signed up → created an alias (undeleted, incl. paused) → mail accepted this month. Note: 'accepted' counts at acceptance into processing; a later Telegram send failure still counts (watch the perm-failed retries stat for that).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 36 },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "min": 0 },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(email_to_telegram_users{state=\"total\",env=~\"$env\"})",
          "legendFormat": "signed up"
        },
        {
          "refId": "B",
          "expr": "sum(email_to_telegram_users{state=\"with_alias\",env=~\"$env\"})",
          "legendFormat": "created an alias"
        },
        {
          "refId": "C",
          "expr": "sum(email_to_telegram_users{state=\"accepted_mail_this_month\",env=~\"$env\"})",
          "legendFormat": "mail accepted this month"
        }
      ]
    },
    {
      "id": 19,
      "type": "bargauge",
      "title": "Active users by plan",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 36 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (plan) (email_to_telegram_active_users_by_plan{env=~\"$env\"})",
          "legendFormat": "{{plan}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Delivered emails per day (30d)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "timeFrom": "30d",
      "hideTimeOverride": false,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "min": 0,
          "custom": { "drawStyle": "bars", "fillOpacity": 80 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(email_to_telegram_delivery_attempts_total{result=\"succeeded\",env=~\"$env\"}[1d]))",
          "legendFormat": "delivered / day"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Users total (30d trend)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "timeFrom": "30d",
      "hideTimeOverride": false,
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "min": 0 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(email_to_telegram_users{state=\"total\",env=~\"$env\"})",
          "legendFormat": "total"
        },
        {
          "refId": "B",
          "expr": "sum(email_to_telegram_users{state=\"with_alias\",env=~\"$env\"})",
          "legendFormat": "with alias"
        }
      ]
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Chats (active)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 50 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(email_to_telegram_chats{state=\"active\",env=~\"$env\"})",
          "legendFormat": "active chats"
        }
      ]
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Attachments storage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 50 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "decimals": 2 },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "email_to_telegram_attachments_stored_bytes{env=~\"$env\"}",
          "legendFormat": "stored"
        }
      ]
    },
    {
      "id": 24,
      "type": "bargauge",
      "title": "Aliases by status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 50 },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "min": 0 },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (email_to_telegram_aliases{env=~\"$env\"})",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 25,
      "type": "logs",
      "title": "App error logs (staging only — prod containers are not shipped to Loki)",
      "description": "Pino level >= 50 (error, fatal) from the staging app container. Promtail runs only on the staging VM with a static env=staging label, so this panel never shows prod.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 55 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{compose_project=\"email-to-telegram\", service=\"app\"} | json | level >= 50"
        }
      ]
    }
  ]
