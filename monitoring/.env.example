# Copy to ~/monitoring/.env on the staging VM and fill values.
# Compose will fail fast if MONITORING_BIND_IP or GRAFANA_ADMIN_PASSWORD are unset.

# Private interface IP that Grafana should bind to. Must be reachable only
# via the VPN / private LAN. Never set this to 0.0.0.0 or a public IP.
MONITORING_BIND_IP=

# Grafana initial admin credentials.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Bearer tokens used by Prometheus to scrape the app /metrics endpoint.
# The deploy workflow writes these into
#   ./prometheus/secrets/staging_token
#   ./prometheus/secrets/prod_token
# Each file must contain only the raw token, no trailing newline.
METRICS_BEARER_TOKEN_STAGING=
METRICS_BEARER_TOKEN_PROD=
