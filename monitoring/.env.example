# Copy to ~/monitoring/.env on the staging VM and fill values.
# Compose will fail fast if any of MONITORING_BIND_IP, GRAFANA_ADMIN_PASSWORD,
# or GRAFANA_ROOT_URL are unset.

# Private interface IP that Grafana should bind to. Must be reachable only
# via the VPN / private LAN. Never set this to 0.0.0.0 or a public IP.
MONITORING_BIND_IP=

# Grafana initial admin credentials.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Full URL operators use to reach Grafana from a browser, including the
# trailing slash. Used by Grafana for redirects, share links, and login flows.
# Example: http://10.0.88.3:3001/
GRAFANA_ROOT_URL=

# Bearer tokens for Prometheus -> app /metrics scraping are NOT set here.
# They are stored as GitHub repository secrets
# (METRICS_BEARER_TOKEN_STAGING, METRICS_BEARER_TOKEN_PROD) and written by
# the deploy workflow into ./prometheus/secrets/{staging_token,prod_token}.
